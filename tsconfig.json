{
    "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "lib": ["ES2022", "DOM", "DOM.Iterable"],
      "jsx": "react-jsx",
      "strict": true,
      "noEmit": true,
      "allowImportingTsExtensions": true,
      "isolatedModules": true,
      "skipLibCheck": true,
      "baseUrl": ".",
      "paths": {
        "@/*": ["resources/js/*"]
      }
    },
    "include": [
      "resources/js/**/*.ts",
      "resources/js/**/*.tsx",
      "resources/js/**/*.d.ts",
      "vite.config.ts"
    ],
    "exclude": ["node_modules", "public", "vendor"]
  }